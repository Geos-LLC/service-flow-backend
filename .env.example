# Service Flow backend — env template
# Copy to .env and fill in. .env is gitignored; never commit real values.

# --- Database (legacy MySQL config, unused if SUPABASE_* is set) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=service_flow

# --- Auth ---
# 64+ random bytes, base64url. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=

# --- Server ---
PORT=3001
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# --- Stripe (use sk_test_ in dev) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- Supabase ---
# Use a `sb_secret_*` (new format) for service role.
# Legacy JWT-style keys (eyJ...) have been disabled on this project.
SUPABASE_URL=https://ezyhbvskbwmwgwyduqpt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (legacy Gmail; production uses SendGrid via SENDGRID_API_KEY at the
#     platform level — see admin dashboard). Leave blank for local dev. ---
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASSWORD=

# --- Uploads ---
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=10485760
